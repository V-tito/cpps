function Fib(M: integer returns integer)
        if (M < 2) then
            M
        else
            Fib(M-1) + Fib(M-2)
        end if
end function

function main(M: integer returns array of integer)
    for i in 1,M
        repeat
            s:=if (i<2) then i else Fib(i) end if
        returns array of s
end for
end function
